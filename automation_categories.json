  {
    "category": "Activate Dataset",
    "description": "Activates a specific schema for a dataset in an organisation. Use when a dataset needs to be activated with a current, in-progress, or backup schema.",
    "trigger_phrases": [
      "activate dataset",
      "dataset activation",
      "activate schema",
      "enable dataset",
      "turn on dataset",
      "activate the dataset"
    ],
    "api_action": "irtbotautomation",
    "fields": [
      {
        "key": "dataset_id",
        "label": "Dataset ID",
        "required": true,
        "type": "string",
        "hint": "e.g. ds_123",
        "extraction_patterns": [
          "dataset {value}",
          "dataset_id {value}",
          "for dataset {value}"
        ]
      },
      {
        "key": "org_id",
        "label": "Organisation ID",
        "required": true,
        "type": "string",
        "hint": "e.g. org_456",
        "extraction_patterns": [
          "org {value}",
          "org_id {value}",
          "for org {value}"
        ]
      },
      {
        "key": "schema_to_activate",
        "label": "Schema name or ID to activate",
        "required": true,
        "type": "string",
        "hint": "e.g. v2_schema",
        "extraction_patterns": [
          "schema {value}",
          "activate schema {value}"
        ]
      },
      {
        "key": "activate_type",
        "label": "Activation type",
        "required": true,
        "type": "enum",
        "enum_values": [
          "current_schema",
          "in_progress_schema",
          "backup_schema"
        ],

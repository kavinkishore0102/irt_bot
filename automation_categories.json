[
  {
    "category": "Extend Trail Period",
    "description": "Extends the trial/trail period expiry date for an organisation. Use when a customer's trial has expired or is about to expire and needs more time.",
    "trigger_phrases": [
      "extend trail period",
      "extend trial period",
      "extend trial",
      "extend the trail",
      "trial expired",
      "trail expired",
      "more trial time",
      "trial extension",
      "extend expiry",
      "extend expiration",
      "give more trial days"
    ],
    "api_action": "irtbotautomation",
    "fields": [
      {
        "key": "org_id",
        "label": "Organisation ID",
        "required": true,
        "type": "string",
        "hint": "e.g. org_123 or the full org identifier",
        "extraction_patterns": [
          "for org {value}",
          "org_id {value}",
          "org {value}",
          "organisation {value}",
          "organization {value}"
        ]
      },
      {
        "key": "extend_period",
        "label": "New expiry date",
        "required": true,
        "type": "date",
        "hint": "Format: YYYY-MM-DD  e.g. 2026-04-28",
        "extraction_patterns": [
          "until {value}",
          "to {value}",
          "till {value}",
          "expiry {value}",
          "date {value}"
        ]
      }
    ],
    "payload_template": {
      "org_id": "{org_id}",
      "extend_period": "{extend_period}"
    }
  },
  {
    "category": "Update Refresh Time",
    "description": "Updates the data refresh schedule for an organisation. Use when someone wants to change when their data refreshes or add new refresh time slots.",
    "trigger_phrases": [
      "update refresh time",
      "change refresh schedule",
      "change refresh time",
      "update refresh schedule",
      "set refresh time",
      "refresh schedule",
      "data refresh timing",
      "update data refresh"
    ],
    "api_action": "irtbotautomation",
    "fields": [
      {
        "key": "org_id",
        "label": "Organisation ID",
        "required": true,
        "type": "string",
        "hint": "e.g. org_123",
        "extraction_patterns": [
          "for org {value}",
          "org_id {value}",
          "org {value}"
        ]
      },
      {
        "key": "timezone",
        "label": "Timezone abbreviation",
        "required": true,
        "type": "string",
        "hint": "e.g. EST, PST, IST, UTC",
        "extraction_patterns": [
          "{value} timezone",
          "timezone {value}",
          "tz {value}"
        ]
      },
      {
        "key": "refreshTime",
        "label": "Refresh times (comma-separated HH:MM)",
        "required": true,
        "type": "string",
        "hint": "e.g. 09:00, 15:00  (multiple times separated by commas)",
        "extraction_patterns": [
          "at {value}",
          "time {value}",
          "times {value}"
        ]
      }
    ],
    "payload_template": {
      "org_id": "{org_id}",
      "timezone": "{timezone}",
      "refreshTime": "{refreshTime}"
    },
    "payload_transform": {
      "refreshTime": "split_by_comma"
    }
  },
  {
    "category": "Admin Email changes",
    "description": "Changes the email address for an admin or regular user account. Use when an admin or user needs their login email updated.",
    "trigger_phrases": [
      "admin email changes",
      "change email",
      "email change",
      "update email",
      "change admin email",
      "change user email",
      "update admin email",
      "email address change",
      "new email",
      "wrong email"
    ],
    "api_action": "irtbotautomation",
    "fields": [
      {
        "key": "role",
        "label": "Role (admin or user)",
        "required": true,
        "type": "enum",
        "enum_values": [
          "admin",
          "user"
        ],
        "hint": "Type admin or user",
        "extraction_patterns": [
          "role {value}",
          "{value} role",
          "as {value}"
        ]
      },
      {
        "key": "old_email",
        "label": "Current email address",
        "required": true,
        "type": "email",
        "hint": "e.g. old@example.com",
        "extraction_patterns": [
          "from {value}",
          "current email {value}",
          "old email {value}"
        ]
      },
      {
        "key": "new_email",
        "label": "New email address",
        "required": true,
        "type": "email",
        "hint": "e.g. new@example.com",
        "extraction_patterns": [
          "to {value}",
          "new email {value}",
          "change to {value}"
        ]
      },
      {
        "key": "user_id",
        "label": "User ID",
        "required": false,
        "required_when": {
          "role": "admin"
        },
        "type": "string",
        "hint": "Required only for admin role change  e.g. user_123",
        "extraction_patterns": [
          "user_id {value}",
          "user {value}",
          "for user {value}"
        ]
      },
      {
        "key": "dataset_id",
        "label": "Dataset ID",
        "required": false,
        "required_when": {
          "role": "admin"
        },
        "type": "string",
        "hint": "Required only for admin role change  e.g. ds_456",
        "extraction_patterns": [
          "dataset {value}",
          "dataset_id {value}"
        ]
      },
      {
        "key": "org_id",
        "label": "Organisation ID",
        "required": false,
        "required_when": {
          "role": "admin"
        },
        "type": "string",
        "hint": "Required only for admin role change  e.g. org_789",
        "extraction_patterns": [
          "org {value}",
          "org_id {value}"
        ]
      }
    ],
    "payload_template": "dynamic_all_provided"
  },
